# .env.example — Template for local environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is listed in .gitignore and will not be committed.
# This example file IS safe to commit — it contains no real secrets.

# Password used to authenticate VNC connections to the desktop.
# Choose a strong passphrase — this is the only thing protecting remote access.
VNC_PASSWORD=change-me

# IP address to bind the VNC port (5901) on the host.
# 127.0.0.1 → localhost only (safest, use an SSH tunnel for remote access)
# 0.0.0.0   → all interfaces (accessible from anywhere on the network)
# 192.168.x.x → a specific LAN interface
BIND_IP=127.0.0.1
